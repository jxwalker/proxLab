# proxlab configuration
# Copy to .env and fill in secrets

# Proxmox — beast (192.168.8.197)
# Create API token: Datacenter > Permissions > API Tokens > Add
# User proxlab@pve needs: VM.Allocate, VM.PowerMgmt, VM.Clone, Datastore.AllocateSpace
PROXMOX_HOST=192.168.8.197
PROXMOX_NODE=beast
PROXMOX_USER=proxlab@pve
PROXMOX_TOKEN_NAME=proxlab
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_STORAGE=vmdata
PROXMOX_TEMPLATE_ID=9000
PROXMOX_VMID_MIN=200
PROXMOX_VMID_MAX=299
PROXMOX_VERIFY_SSL=false

# TrueNAS SCALE — truenas.local (192.168.8.198)
# Generate API key: System > API Keys > Add
TRUENAS_HOST=192.168.8.198
TRUENAS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRUENAS_POOL=bigpool
TRUENAS_PROXLAB_PARENT=bigpool/proxlab
TRUENAS_NFS_SERVER=192.168.8.198
TRUENAS_VERIFY_SSL=false

# Postgres LXC — create this LXC first, install postgresql, set superuser DSN
# Example: postgresql://postgres:yourpassword@192.168.8.xxx/postgres
POSTGRES_DSN=postgresql://postgres:changeme@192.168.8.xxx/postgres

# proxlab API auth token — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
PROXLAB_API_TOKEN=changeme
